generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String   @unique @db.VarChar(150)
  password  String   @db.VarChar(255)
  name      String   @db.VarChar(100)
  role      String   @default("admin") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@map("users")
}

model Gym {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @db.VarChar(100)
  city      String   @db.VarChar(50)
  capacity  Int
  status    String   @default("active") @db.VarChar(20)
  opensAt   String   @map("opens_at") @db.VarChar(5)
  closesAt  String   @map("closes_at") @db.VarChar(5)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  members   Member[]
  checkins  Checkin[]
  payments  Payment[]
  anomalies Anomaly[]

  @@map("gyms")
}

model Member {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gymId         String    @map("gym_id") @db.Uuid
  name          String    @db.VarChar(100)
  email         String    @unique @db.VarChar(150)
  phone         String    @db.VarChar(15)
  planType      String    @map("plan_type") @db.VarChar(20)
  memberType    String    @map("member_type") @db.VarChar(20)
  status        String    @default("active") @db.VarChar(20)
  joinedAt      DateTime  @map("joined_at") @db.Timestamptz()
  planExpiresAt DateTime  @map("plan_expires_at") @db.Timestamptz()
  lastCheckinAt DateTime? @map("last_checkin_at") @db.Timestamptz()
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  gym      Gym       @relation(fields: [gymId], references: [id])
  checkins Checkin[]
  payments Payment[]

  @@index([gymId], map: "idx_members_gym_id")
  @@map("members")
}

model Checkin {
  id          BigInt    @id @default(autoincrement())
  memberId    String    @map("member_id") @db.Uuid
  gymId       String    @map("gym_id") @db.Uuid
  checkedIn   DateTime  @map("checked_in") @db.Timestamptz()
  checkedOut  DateTime? @map("checked_out") @db.Timestamptz()
  durationMin Int?      @map("duration_min")

  member Member @relation(fields: [memberId], references: [id])
  gym    Gym    @relation(fields: [gymId], references: [id])

  @@index([memberId, checkedIn(sort: Desc)], map: "idx_checkins_member")
  @@map("checkins")
}

model Payment {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  memberId    String   @map("member_id") @db.Uuid
  gymId       String   @map("gym_id") @db.Uuid
  amount      Decimal  @db.Decimal(10, 2)
  planType    String   @map("plan_type") @db.VarChar(20)
  paymentType String   @map("payment_type") @db.VarChar(20)
  paidAt      DateTime @map("paid_at") @db.Timestamptz()

  member Member @relation(fields: [memberId], references: [id])
  gym    Gym    @relation(fields: [gymId], references: [id])

  @@index([gymId, paidAt(sort: Desc)], map: "idx_payments_gym_date")
  @@index([paidAt(sort: Desc)], map: "idx_payments_date")
  @@map("payments")
}

model Anomaly {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gymId      String    @map("gym_id") @db.Uuid
  type       String    @db.VarChar(30)
  severity   String    @db.VarChar(20)
  message    String
  resolved   Boolean   @default(false)
  dismissed  Boolean   @default(false)
  detectedAt DateTime  @default(now()) @map("detected_at") @db.Timestamptz()
  resolvedAt DateTime? @map("resolved_at") @db.Timestamptz()

  gym Gym @relation(fields: [gymId], references: [id])

  @@map("anomalies")
}
